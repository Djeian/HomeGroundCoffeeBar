@model List<HomeGroundCoffeeBar.Models.Order>
@{
    ViewData["Title"] = "Order History";
    ViewBag.Page = "orderHistory";
}

<link rel="stylesheet" href="/css/leaflet.css" />
<link rel="stylesheet" href="/css/sweetalert2.min.css" />

<script src="/js/leaflet.js"></script>
<script src="/js/sweetalert2.min.js"></script>

<div class="order-history-container">
    <div class="order-history-header">
        <h1>Order History</h1>
        <p>Track all your past orders</p>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-orders">
            <img src="/img/logowhite.png" alt="No orders" />
            <h2>No orders yet</h2>
            <p>Looks like you haven't placed any orders yet.</p>
            <a href="/Home/Menu" class="btn-order-now">Order Now</a>
        </div>
    }
    else
    {
        <div class="orders-list">
            @foreach (var order in Model)
            {
                <div class="order-card">
                    <div class="order-card-header">
                        <div class="order-id-section">
                            <span class="order-label">Order ID</span>
                            <span class="order-id">@order.OrderId</span>
                        </div>
                        <div class="order-status-badge status-@order.Status.ToLower()">
                            @order.Status
                        </div>
                    </div>

                    <div class="order-card-body">
                        <div class="order-items-preview">
                            @foreach (var item in order.Items.Take(3))
                            {
                                <div class="order-item-preview">
                                    <img src="@item.Image" alt="@item.ProductName" />
                                    <div class="order-item-info">
                                        <span class="item-name">@item.ProductName</span>
                                    <span class="item-qty">x@(item.Quantity)</span>
                                     </div>
                                    <span class="item-price">
                                        ₱@((item.Price * item.Quantity).ToString("F2"))
                                    </span>
                                </div>
                            }
                            @if (order.Items.Count > 3)
                            {
                                <p class="more-items">
                                    +@(order.Items.Count - 3) more item(s)
                                </p>
                            }
                        </div>

                        <div class="order-card-footer">
                            <div class="order-meta">
                                <div class="order-meta-item">
                                    <span class="meta-label">Date</span>
                                    <span class="meta-value">
                                        @order.CreatedAt.ToString("MMM dd, yyyy")
                                    </span>
                                </div>
                                <div class="order-meta-item">
                                    <span class="meta-label">Payment</span>
                                    <span class="meta-value">
                                        @order.PaymentMethod.ToUpper()
                                    </span>
                                </div>
                                <div class="order-meta-item">
                                    <span class="meta-label">Points Earned</span>
                                    <span class="meta-value points">
                                        +@order.PointsEarned pts
                                    </span>
                                </div>
                            </div>
                            <div class="order-total">
                                <span class="total-label">Total</span>
                                <span class="total-value">
                                    ₱@order.Total.ToString("F2")
                                </span>
                            </div>
                                    @if (order.Status == "Pending")
                                        {
                                            <button class="btn-cancel-order" data-orderid="@order.OrderId">
                                                Cancel Order
                                            </button>
                                        }
                                        @if (order.Status == "Otw")
                                        {
                                            <button class="btn-track-rider" data-orderid="@order.OrderId">
                                                Track Rider
                                            </button>
                                        }
                                        @if (order.Status == "Delivered")
                                        {
                                            <button class="btn-order-received" data-orderid="@order.OrderId">Order Received</button>
                                        }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
.order-history-container {
    max-width: 800px;
    margin: 40px auto;
    padding: 0 20px;
    font-family: 'Poppins', sans-serif;
}

.order-history-header {
    margin-bottom: 30px;
}

.order-history-header h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #dbcdc8;
    margin: 0;
}

.order-history-header p {
    color: #888;
    margin: 5px 0 0;
}

.empty-orders {
    text-align: center;
    padding: 80px 20px;
    color: #888;
}

.empty-orders img {
    width: 80px;
    opacity: 0.3;
    margin-bottom: 20px;
    filter: invert(1);
}

.empty-orders h2 { color: #2c1810; margin-bottom: 10px; }

.btn-order-now {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 30px;
    background: #614c3a;
    color: white;
    border-radius: 25px;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.3s;
}

.btn-order-now:hover { background: #2c1810; }

.orders-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.order-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    overflow: hidden;
    border: 1px solid #f0e8e0;
    transition: transform 0.2s, box-shadow 0.2s;
}

.order-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
}

.order-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    background: #faf6f2;
    border-bottom: 1px solid #f0e8e0;
}

.order-label {
    font-size: 0.75rem;
    color: #888;
    display: block;
}

.order-id {
    font-size: 0.95rem;
    font-weight: 700;
    color: #2c1810;
}

.order-status-badge {
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.status-pending   { background: #fff3cd; color: #856404; }
.status-cancelled { background: #f8d7da; color: #721c24; }
.status-confirmed { background: #d1ecf1; color: #0c5460; }
.status-preparing { background: #cce5ff; color: #004085; }
.status-pickup    { background: #d4edda; color: #155724; }
.status-otw       { background: #e2d9f3; color: #4a235a; }
.status-delivered { background: #d4edda; color: #155724; }
.status-completed { background: #614c3a; color: white;   }

.order-card-body { padding: 20px; }

.order-items-preview {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid #f0e8e0;
}

.order-item-preview {
    display: flex;
    align-items: center;
    gap: 12px;
}

.order-item-preview img {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: 8px;
}

.order-item-info {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.item-name {
    font-weight: 600;
    color: #2c1810;
    font-size: 0.9rem;
}

.item-qty  { color: #888; font-size: 0.8rem; }
.item-price { font-weight: 600; color: #614c3a; }
.more-items { color: #888; font-size: 0.85rem; margin: 0; }

.order-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
}

.order-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.order-meta-item {
    display: flex;
    gap: 8px;
    align-items: center;
}

.meta-label {
    font-size: 0.8rem;
    color: #888;
    min-width: 90px;
}

.meta-value {
    font-size: 0.85rem;
    font-weight: 600;
    color: #2c1810;
}

.meta-value.points { color: #614c3a; }

.order-total { text-align: right; }

.total-label {
    display: block;
    font-size: 0.8rem;
    color: #888;
}

.total-value {
    font-size: 1.3rem;
    font-weight: 700;
    color: #2c1810;
}


.order-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
}

.btn-cancel-order {
    padding: 8px 18px;
    background: transparent;
    border: 2px solid #e63946;
    color: #e63946;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Poppins', sans-serif;
}

.btn-cancel-order:hover {
    background: #e63946;
    color: white;
}

.btn-order-received {
    padding: 8px 18px;
    background: #614c3a;
    border: none;
    color: white;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Poppins', sans-serif;
}

.btn-order-received:hover {
    background: #2c1810;
}
</style>


<!-- Leaflet from CDN - more reliable than local -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<!-- Tracking Modal -->
<div id="trackingModal" style="
    display:none; position:fixed; inset:0;
    background:rgba(0,0,0,0.7); z-index:9999;
    align-items:center; justify-content:center; padding:20px;">
    <div style="
        background:#1F1B16; border-radius:16px;
        width:100%; max-width:600px;
        border:1px solid #4f4439; overflow:hidden;">
        <div style="
            display:flex; justify-content:space-between; align-items:center;
            padding:16px 20px; border-bottom:1px solid #4f4439;">
            <h2 style="color:#CCBEA8; margin:0; font-size:18px;">📍 Live Rider Tracking</h2>
            <button id="closeTrackingModal" style="
                background:none; border:none; color:#CCBEA8;
                font-size:24px; cursor:pointer; line-height:1;">✕</button>
        </div>
        <div id="trackingMap" style="height:350px; width:100%;"></div>
        <div style="padding:16px 20px; color:#B3A999; font-size:13px; display:flex; justify-content:space-between;">
            <span id="trackingStatus">Fetching rider location...</span>
            <span id="trackingTime"></span>
        </div>
    </div>
</div>

<script>
let trackingMap      = null;
let riderMarker      = null;
let trackingInterval = null;

document.addEventListener('click', async function (e) {

    // CANCEL ORDER
    if (e.target.classList.contains('btn-cancel-order')) {
        if (!confirm('Are you sure you want to cancel this order?')) return;
        const orderId = e.target.dataset.orderid;
        const res  = await fetch('/Home/UpdateMyOrderStatus', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ orderId, status: 'Cancelled' })
        });
        const data = await res.json();
        if (data.success) location.reload();
        else alert(data.message);
    }

    // ORDER RECEIVED
    if (e.target.classList.contains('btn-order-received')) {
        if (!confirm('Confirm that you have received your order?')) return;
        const orderId = e.target.dataset.orderid;
        const res  = await fetch('/Home/UpdateMyOrderStatus', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ orderId, status: 'Completed' })
        });
        const data = await res.json();
        if (data.success) location.reload();
        else alert(data.message);
    }

    // TRACK RIDER
    if (e.target.classList.contains('btn-track-rider')) {
        const orderId = e.target.dataset.orderid;
        openTrackingModal(orderId);
    }
});

function openTrackingModal(orderId) {
    const modal = document.getElementById('trackingModal');
    modal.style.display = 'flex';

    document.getElementById('trackingStatus').textContent = 'Fetching rider location...';
    document.getElementById('trackingTime').textContent   = '';

    // Clear old interval
    if (trackingInterval) {
        clearInterval(trackingInterval);
        trackingInterval = null;
    }

    // Init map after modal is visible
    setTimeout(() => {
        if (!trackingMap) {
            trackingMap = L.map('trackingMap').setView([14.5995, 120.9842], 14);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(trackingMap);
        } else {
            trackingMap.invalidateSize();
        }

        // Fetch immediately then poll every 5s
        fetchRiderLocation(orderId);
        trackingInterval = setInterval(() => fetchRiderLocation(orderId), 5000);
    }, 200);
}

async function fetchRiderLocation(orderId) {
    try {
        const res  = await fetch(`/Home/GetRiderLocation?orderId=${orderId}`);
        const data = await res.json();

        if (!data.found) {
            document.getElementById('trackingStatus').textContent = 'Rider location not available yet. Waiting...';
            return;
        }

        const lat = data.latitude;
        const lng = data.longitude;

        document.getElementById('trackingStatus').textContent = '🛵 Rider is on the way!';
        document.getElementById('trackingTime').textContent   = `Updated: ${data.updatedAt}`;

        if (!riderMarker) {
            riderMarker = L.marker([lat, lng], {
                icon: L.divIcon({
                    className: '',
                    html: `<div style="
                        background:#614c3a; width:20px; height:20px;
                        border-radius:50%; border:3px solid #CCBEA8;
                        box-shadow:0 0 8px rgba(204,190,168,0.8);">
                    </div>`,
                    iconAnchor: [10, 10]
                })
            }).addTo(trackingMap).bindPopup('🛵 Your Rider');
        } else {
            riderMarker.setLatLng([lat, lng]);
        }

        trackingMap.setView([lat, lng], 15);
    } catch (err) {
        document.getElementById('trackingStatus').textContent = 'Error fetching location.';
    }
}

document.getElementById('closeTrackingModal').addEventListener('click', () => {
    if (trackingInterval) {
        clearInterval(trackingInterval);
        trackingInterval = null;
    }
    riderMarker = null;
    if (trackingMap) {
        trackingMap.remove();
        trackingMap = null;
    }
    document.getElementById('trackingModal').style.display = 'none';
});
</script>