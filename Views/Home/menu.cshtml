@model List<HomeGroundCoffeeBar.Models.Product>
@{
    ViewData["Title"] = "Menu";
    ViewData["Page"] = "menu";
}

<div class="banner">
    <div class="text-class">
        <h1 class="banner-text">Warm it. Chill it. <br>Feel it.</h1>
        <p class="banner-paragraph">Embrace the moment with smooth sips<br>and perfectly balanced blends.</p>
    </div>
    <a href="#menu" class="banner-btn">Discover the flavors</a>
</div>

<div class="menu-container" id="menu">
    <div class="menu-header">
        <h1 class="menu-title">Menu</h1>
    </div>

    <div class="menu-main">
        <div class="sidebar">
            <h2 class="category-title">Sips & Bites</h2>
            <ul class="category-list">
                <li class="category-item active" data-category="all">All</li>
                <li class="category-item" data-category="cold">Cold</li>
                <li class="category-item" data-category="hot">Hot</li>
                <li class="category-item" data-category="burger">Burger</li>
            </ul>
        </div>

        <div class="product-container">
            <div class="title">
                <h3 class="title-menu">
                    <span class="menu-path">Menu /</span>
                    <span class="menu-current">Sip & Bites</span>
                </h3>
            </div>

            <div class="product-card-container">
                @foreach (var product in Model)
                {
                    <div class="product-card" id="@product.Category" data-price="@product.Price">
                        <img src="@product.Image" alt="@product.Name" />
                        <p>@product.Name</p>
                        @if (product.Stock <= 0)
                        {
                            <span class="out-of-stock-badge">Out of Stock</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<button id="cartButton" class="cart-button">
    <span class="cart-icon">🛒</span>
    <span class="cart-count">0</span>
</button>